# ========================================
# MediFlow Environment Variables
# ========================================
# Copy this file to .env.local and fill in your actual values

# ========================================
# Supabase Configuration
# ========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# API Configuration
# ========================================
# For development (local): http://localhost:3001
# For production (Vercel): https://your-project.vercel.app
VITE_API_BASE_URL=http://localhost:3001
VITE_API_PORT=3001
VITE_API_TIMEOUT=30000

# ========================================
# Razorpay Configuration
# ========================================
VITE_RAZORPAY_KEY_ID=rzp_test_1234567890

# ========================================
# Application Configuration
# ========================================
VITE_APP_NAME=MediFlow
VITE_APP_VERSION=1.0.0

# ========================================
# Environment
# ========================================
NODE_ENV=development

# ========================================
# VERCEL SPECIFIC SETTINGS
# ========================================
# When deploying to Vercel, set:
# - VITE_API_BASE_URL to your Vercel domain (https://your-project.vercel.app)
# - VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY from Supabase
# - VITE_RAZORPAY_KEY_ID for production Razorpay key
# - NODE_ENV to production

